# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# === Database ===========================================================
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_PASSWORD=change-me-pyplanet-password
DB_NAME=pyplanet
DB_USER=pyplanet

# === Trackmania dedicated server ========================================
# A dedicated-server account from https://www.trackmania.com/player/dedicated-servers
TM_MASTERSERVER_LOGIN=your-dedicated-account-login
TM_MASTERSERVER_PASSWORD=your-dedicated-account-password

# Public server name shown in the in-game browser ($ codes allowed for colors).
TM_SERVER_NAME=$o$f90My PyPlanet Server

# XML-RPC passwords used between the controller and the dedicated server.
# Pick your own strong values; SUPERADMIN is the one the controller logs in with.
XMLRPC_SUPERADMIN=change-me-superadmin
XMLRPC_ADMIN=change-me-admin
XMLRPC_USER=change-me-user

# Optional bandwidth tuning (kbit/s). Raise for many players/spectators.
TM_UPLOADRATE=30000
TM_DOWNLOADRATE=30000

# === PyPlanet controller ================================================
# Comma-separated player logins that become in-game owners/admins.
PYPLANET_OWNERS=your-ubisoft-login

# MatchSettings file under UserData/Maps/MatchSettings/ inside the dedicated.
MAP_MATCHSETTINGS=maplist.txt
